# Example only — do NOT edit. Run `python setup.py` to generate the real .env
# with values discovered from your AWS account.
export BUCKET="<your-bucket-name>"
export REGION="us-west-2"
export ACCOUNT_ID="<your-aws-account-id>"
export PROFILE="default"
export LAMBDA_ROLE_ARN="arn:aws:iam::<account>:role/apo-tutorial-lambda-role"
export APO_ENDPOINT="https://beta.us-west-2.controlplane.bedrock.aws.dev"
export APO_USE_REFERENCE="1"   # 1 = replay (bundled results), 0 = live
